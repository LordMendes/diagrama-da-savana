# Copie para `backend/.env` e ajuste. Não commitar `.env` com segredos.
# Em dev/test, `config/runtime.exs` aplica este arquivo ao ambiente (export no shell tem prioridade).

# --- Banco (dev/test) ---
# Público: uma URL Ecto **ou** variáveis separadas (não defina os dois para o mesmo banco).
# Público: URL alinhada ao docker compose na raiz (Postgres no host na porta 5433).
DATABASE_URL=ecto://postgres:postgres@localhost:5433/diagrama_savana_dev
# Público: alternativa à DATABASE_URL (veja config/dev.exs e config/test.exs).
# DATABASE_HOST=localhost
# DATABASE_PORT=5433
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=diagrama_savana_dev

# --- brapi.dev (config/runtime.exs) ---
# Público: base da API (padrão no código se omitido: https://brapi.dev/api).
# BRAPI_BASE_URL=https://brapi.dev/api
# Segredo: token conforme plano; não commitar valor real.
# BRAPI_API_TOKEN=
# Público: opcionais — padrão 60 se omitidos.
# BRAPI_RATE_LIMIT_PER_MINUTE=60
# BRAPI_CACHE_TTL_SECONDS=60
# Público: máximo de tickers por requisição em lote (`/quote/A,B,...`) quando BRAPI_QUOTE_BATCH_ENABLED=true. Padrão 1.
# BRAPI_QUOTE_BATCH_SIZE=1
# Público: defina true/1/yes só se o plano brapi permitir vários tickers na mesma URL; padrão desligado (uma requisição por ticker).
# BRAPI_QUOTE_BATCH_ENABLED=

# Público: TTL em segundos do cache da simulação de aporte (POST .../simulacao_aporte); padrão 1800 (30 min).
# SIMULACAO_APORTE_CACHE_TTL_SECONDS=1800

# --- Desenvolvimento local (opcional) ---
# Público: frontend para links em e-mail (ex.: reset de senha).
# PUBLIC_APP_URL=http://localhost:5173
# Público: MailHog no Compose (SMTP 1025, UI 8025).
# SMTP_HOST=localhost
# SMTP_PORT=1025
# MAILER_FROM_EMAIL=nao-responda@localhost
# MAILER_FROM_NAME=Diagrama da Savana

# --- Produção (release / PHX_SERVER) ---
# Obrigatórios em prod: DATABASE_URL, SECRET_KEY_BASE, GUARDIAN_SECRET_KEY (gerar com mix phx.gen.secret).
# Segredo: não commitar esses valores.
# Comuns: PHX_HOST, PORT, POOL_SIZE, PUBLIC_APP_URL, MAILER_FROM_EMAIL, MAILER_FROM_NAME, DNS_CLUSTER_QUERY, ECTO_IPV6.
# Público: origens CORS permitidas para o frontend (separadas por vírgula). Se omitida ou vazia, usa PUBLIC_APP_URL (ou https://PHX_HOST).
# CORS_ALLOWED_ORIGINS=https://app.exemplo.com,https://www.exemplo.com
