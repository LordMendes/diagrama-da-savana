# Copy to `.env` locally if you need to override defaults (do not commit secrets).

# API base URL — público / não segredo: URL base da API Phoenix (sem barra final).
# Vazio = mesma origem; em `pnpm dev` o Vite encaminha `/api/*` para o Phoenix (ver vite.config).
# Use URL absoluta (ex.: http://localhost:4000) apenas se precisar; o backend deve permitir CORS nesse caso.
VITE_API_BASE_URL=
